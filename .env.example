# Database - Auto-populated by the sandbox environment
DATABASE_URL=

# Better Auth - Session encryption secret (auto-generated during init)
# Required for auth to work. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Better Auth - Trusted origins for CORS/cookie security
# The sandbox automatically injects the preview URL
# For production, add your domain(s) here (comma-separated)
TRUSTED_ORIGINS=

# Optional: Better Auth base URL (defaults to window.location.origin on client)
# BETTER_AUTH_URL=

# Optional: OAuth providers (leave empty to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
